{
  "name": "travel-chatbot",
  "version": "1.0.0",
  "description": "AI-powered travel chatbot with Google Sheets + Claude AI",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "build": "cd client && npm install && npm run build",
    "dev": "concurrently \"nodemon server.js\" \"cd client && npm start\"",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "googleapis": "^118.0.0",
    "nodemailer": "^6.9.3",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^2.0.22"
  }
}
